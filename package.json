{
  "name": "bridgegit",
  "version": "0.8.0",
  "description": "Git GUI + PowerShell terminal desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vue-tsc --noEmit -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:win:portable": "npm run build && electron-builder --win portable",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "postinstall": "npm run rebuild:native",
    "start": "node scripts/start.mjs",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "git",
    "terminal",
    "electron",
    "vue"
  ],
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@uiw/codemirror-theme-github": "^4.25.8",
    "@uiw/codemirror-theme-nord": "^4.25.8",
    "electron-store": "^11.0.2",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "dompurify": "^3.3.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "marked": "^17.0.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
